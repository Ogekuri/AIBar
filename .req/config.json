{
  "guidelines-dir": "guidelines",
  "docs-dir": "docs",
  "tests-dir": "tests",
  "src-dir": [
    "src",
    "scripts",
    ".github/workflows"
  ],
  "static-check": {
    "C": [
      {
        "module": "Command",
        "cmd": "cppcheck",
        "params": [
          "--error-exitcode=1",
          "--enable=warning,style,performance,portability",
          "--std=c11"
        ]
      },
      {
        "module": "Command",
        "cmd": "clang-format",
        "params": [
          "--dry-run",
          "--Werror"
        ]
      }
    ],
    "C++": [
      {
        "module": "Command",
        "cmd": "cppcheck",
        "params": [
          "--error-exitcode=1",
          "--enable=warning,style,performance,portability",
          "--std=c++20"
        ]
      },
      {
        "module": "Command",
        "cmd": "clang-format",
        "params": [
          "--dry-run",
          "--Werror"
        ]
      }
    ],
    "Python": [
      {
        "module": "Pylance"
      },
      {
        "module": "Ruff"
      }
    ],
    "JavaScript": [
      {
        "module": "Command",
        "cmd": "scripts/check-js-syntax.sh",
        "params": []
      }
    ]
  },
  "providers": [
    "claude:prompts",
    "github:skills",
    "codex:prompts",
    "opencode:agents",
    "gemini:prompts",
    "kiro:agents"
  ],
  "preserve-models": false
}